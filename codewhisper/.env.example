# ══════════════════════════════════════════════════════════════════════════════
# CodeWhisper — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in every value marked REQUIRED.
#   Optional values have working defaults — change only when needed.
#
# ⚠️  NEVER commit .env to version control.
#     It is already listed in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════


# ── Flask ─────────────────────────────────────────────────────────────────────

# Selects the config class (DevelopmentConfig / ProductionConfig / TestingConfig).
# Values: development | production | testing
FLASK_ENV=development

# Entry-point module used by `flask run` and gunicorn.
FLASK_APP=run.py

# Long random string for signing cookies and sessions.
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-generate-with-secrets.token_hex-32


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────

# SQLAlchemy-compatible connection URL.
# REQUIRED for development / production.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
#
# Local Docker (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://codewhisper_user:codewhisper_pass@localhost:5432/codewhisper_db
#
# Managed DB examples:
#   Render:  postgresql://user:pass@dpg-xxxx.oregon-postgres.render.com/codewhisper
#   Railway: postgresql://postgres:pass@monorail.proxy.rlwy.net:PORT/railway


# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection URL used for:
#   • JWT token blocklist (logout invalidation)
#   • Hint sequence cache (24-hour TTL per problem hash)
#   • Per-session hint-index pointer (1-hour TTL)
# REQUIRED for development / production.
#
# Local Docker (matches docker-compose.yml defaults):
REDIS_URL=redis://localhost:6379/0
#
# Managed Redis examples:
#   Render:  redis://default:password@redis-xxxx.render.com:6379
#   Railway: redis://default:pass@monorail.proxy.rlwy.net:PORT


# ── JWT Authentication ────────────────────────────────────────────────────────

# Secret used to sign and verify JWT access tokens.
# REQUIRED — must be DIFFERENT from SECRET_KEY.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-generate-with-secrets.token_hex-32

# How long (seconds) a JWT access token stays valid.
# Default 3600 (1 hour). Use 300 for stricter security in production.
JWT_ACCESS_TOKEN_EXPIRES=3600


# ── LLM Provider ─────────────────────────────────────────────────────────────
#
# CodeWhisper supports three LLM backends, switchable via LLM_PROVIDER.
# No code changes needed — just set the variable and the matching API key.
#
# Provider comparison:
#   groq   — 200-315 tok/s, free tier, llama-3.3-70b  ← RECOMMENDED
#   openai — GPT-4o, pay-per-token, best quality
#   claude — Claude 3.5 Sonnet, pay-per-token
#
# Values: groq | openai | claude
# Default: groq
LLM_PROVIDER=groq


# ── Groq (Default / Recommended) ─────────────────────────────────────────────
#
# Groq runs open-source models on LPU hardware for blazing-fast inference.
# Free tier available — no credit card required.
#
# Sign up & get your key: https://console.groq.com/keys
# API keys start with: gsk_
#
# REQUIRED when LLM_PROVIDER=groq
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY

# Groq model selection. Current production models (June 2025):
#
#   Model                      Context   Speed          Best for
#   ─────────────────────────  ────────  ─────────────  ─────────────────────
#   llama-3.3-70b-versatile    128K      Very Fast      General purpose ← default
#   llama-3.1-8b-instant       128K      Ultra Fast     Dev/testing, quick tasks
#   llama-3.3-70b-specdec      128K      Fastest 70B    Complex reasoning
#   meta-llama/llama-4-scout   512K      Fast           Very long documents
#
# Full list: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile


# ── OpenAI (Optional Fallback) ────────────────────────────────────────────────
#
# Only required when LLM_PROVIDER=openai.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_KEY

# OpenAI model. Default: gpt-4o
# Other options: gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o


# ── Anthropic Claude (Optional Fallback) ─────────────────────────────────────
#
# Only required when LLM_PROVIDER=claude.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY

# Claude model. Default: claude-3-5-sonnet-20241022
CLAUDE_MODEL=claude-3-5-sonnet-20241022


# ── CORS ──────────────────────────────────────────────────────────────────────

# Allowed cross-origin request origins.
# Development: * (open to all)
# Production:  restrict to your frontend, e.g. https://codewhisper.io
CORS_ORIGINS=*
